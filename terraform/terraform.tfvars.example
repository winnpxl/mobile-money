# ──────────────────────────────────────────────────────────────────────────────
# Example variable values – copy to terraform.tfvars and fill in secrets
# ──────────────────────────────────────────────────────────────────────────────

project     = "mobile-money"
environment = "staging"
aws_region  = "us-east-1"

# Networking
vpc_cidr = "10.0.0.0/16"
az_count = 2

# Application
app_port        = 3000
container_image = "shantelpeters/mobile-money:latest"
task_cpu        = 256
task_memory     = 512
desired_count   = 2
max_count       = 6

# Database
db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
db_name              = "mobilemoney_stellar"
db_username          = "mobilemoney"
db_password          = "REPLACE_WITH_SECURE_PASSWORD"
db_multi_az          = false

# Redis
redis_node_type          = "cache.t3.micro"
redis_num_cache_clusters = 1

# S3
s3_bucket_name = "mobile-money-kyc-documents"
