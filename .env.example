# .env.example
#
# Copy this file to .env and fill in real values.
#   cp .env.example .env

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ---------------------------------------------------------------------------
# Rate Limiting
# Controls how many requests a single IP can make within a time window.
# Defaults: 100 requests per 15 minutes — identical to the previous
# hardcoded values, so existing deployments are unaffected if these vars
# are not set.
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000      # window length in milliseconds (900000 = 15 min)
RATE_LIMIT_MAX_REQUESTS=100      # max requests per IP per window

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/mobilemoney_stellar

# ---------------------------------------------------------------------------
# Redis (for distributed locks)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Stellar Network
# ---------------------------------------------------------------------------
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_ISSUER_SECRET=YOUR_STELLAR_SECRET_KEY

# ---------------------------------------------------------------------------
# Mobile Money Providers
# ---------------------------------------------------------------------------
MTN_API_KEY=your_mtn_api_key
MTN_API_SECRET=your_mtn_api_secret
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key

AIRTEL_API_KEY=your_airtel_api_key
AIRTEL_API_SECRET=your_airtel_api_secret

ORANGE_API_KEY=your_orange_api_key
ORANGE_API_SECRET=your_orange_api_secret

# ---------------------------------------------------------------------------
# Request Timeout
# ---------------------------------------------------------------------------
REQUEST_TIMEOUT_MS=30000
